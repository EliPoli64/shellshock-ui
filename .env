# Solana Network (devnet, testnet, mainnet-beta)
VITE_SOLANA_NETWORK=devnet

# Solana RPC Provider
# Default public endpoint (unstable/rate-limited)
# VITE_SOLANA_RPC_HTTP_URL=https://api.devnet.solana.com

# Recommended: Use a private provider for better stability (Helius, Alchemy, QuickNode, etc.)
VITE_SOLANA_RPC_HTTP_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Relay Server configuration
VITE_RELAY_HTTP_URL=http://localhost:8080
VITE_RELAY_WS_URL=ws://localhost:8080/ws

# Backend Server configuration
VITE_BACKEND_URL=http://localhost:3010
